# === fansone-downloader Environment Variables ===
# Copy this file to .env and fill in actual values
# NEVER commit .env to git

# --- Login credentials (used for session-based auth) ---
FANSONE_EMAIL=your@email.com
FANSONE_PASSWORD=your_password

# --- Download settings ---
OUTPUT_DIR=./downloads
# Quality: best, worst, or a specific height like 1080, 720, 480
QUALITY=best
